<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion Foot - Stats</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">
    <nav class="bg-indigo-600 p-4 text-white shadow-md">
        <div class="container mx-auto flex justify-between items-center">
            <span class="font-bold text-xl">FootManager</span>
            <div class="space-x-4">
                <a href="/" class="hover:underline font-semibold">Dashboard</a>
                <a href="/clubs" class="hover:underline">Clubs</a>
                <a href="/footballers" class="hover:underline">Joueurs</a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto mt-10 px-4">
        <h1 class="text-3xl font-extrabold text-gray-900 mb-8">Statistiques des Effectifs</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-emerald-100 flex items-center space-x-4">
                <div class="p-3 bg-emerald-100 text-emerald-600 rounded-full">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Club le plus peuplé</p>
                    <p class="text-2xl font-bold text-gray-900"><%= maxClub.nom_club %></p>
                    <p class="text-sm text-emerald-600 font-semibold"><%= maxClub.total %> Joueurs</p>
                </div>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-sm border border-rose-100 flex items-center space-x-4">
                <div class="p-3 bg-rose-100 text-rose-600 rounded-full">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0v-8m0 8l-8-8-4 4-6-6"></path></svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Club le moins peuplé</p>
                    <p class="text-2xl font-bold text-gray-900"><%= minClub.nom_club %></p>
                    <p class="text-sm text-rose-600 font-semibold"><%= minClub.total %> Joueur(s)</p>
                </div>
            </div>
        </div>
    </main>
</body>
</html>