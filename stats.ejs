<%- include('layout', { body: `
    <div class="space-y-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Vue d'ensemble des Effectifs</h1>
            <p class="text-sm text-gray-500 mt-1">Analyse quantitative de la répartition des joueurs par structure.</p>
        </div>
    
        <% if (maxClub && minClub) { %>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div class="bg-white overflow-hidden shadow rounded-lg border-l-4 border-green-500">
                <div class="px-4 py-5 sm:p-6">
                    <dt class="text-sm font-medium text-gray-500 truncate">Effectif le plus élevé</dt>
                    <dd class="mt-1 text-3xl font-semibold text-gray-900">${maxClub.nom_club}</dd>
                    <dd class="mt-2 text-sm text-green-600 font-medium">${maxClub.total_joueurs} joueurs enregistrés</dd>
                </div>
            </div>
            <div class="bg-white overflow-hidden shadow rounded-lg border-l-4 border-amber-500">
                <div class="px-4 py-5 sm:p-6">
                    <dt class="text-sm font-medium text-gray-500 truncate">Effectif le plus faible</dt>
                    <dd class="mt-1 text-3xl font-semibold text-gray-900">${minClub.nom_club}</dd>
                    <dd class="mt-2 text-sm text-amber-600 font-medium">${minClub.total_joueurs} joueurs enregistrés</dd>
                </div>
            </div>
        </div>
        <% } %>
    
        <div class="flex flex-col">
            <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                    <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                        <table class="min-w-full divide-y divide-gray-200 bg-white">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nom du Club</th>
                                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre de Joueurs</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                ${stats.map(item => `
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${item.nom_club}</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500 font-semibold">${item.total_joueurs}</td>
                                </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    ` }) %>